{
  "name": "Synthwave",
  "description": "Retro sunset — magenta & electric orange over a neon horizon grid.",
  "developer": { "name": "Latif" },
  "manifest_version": 3,
  "version": "1.0",
  "mod": {
    "license": "",
    "schema_version": 1,
    "payload": {
      "theme": {
        "dark": {
          "gx_accent":         { "h": 330, "s": 100, "l": 59 },
          "gx_secondary_base": { "h": 268, "s": 41, "l": 15 },
          "gx_accent_2":       { "h": 35, "s": 100, "l": 64 }
        },
        "light": {
          "gx_accent":         { "h": 330, "s": 90, "l": 52 },
          "gx_secondary_base": { "h": 268, "s": 35, "l": 95 },
          "gx_accent_2":       { "h": 35, "s": 90, "l": 48 }
        }
      },
      "wallpaper": {
        "dark":  { "type": "live", "source": "wallpaper.js" },
        "light": { "type": "live", "source": "wallpaper.js" }
      },
      "shaders": {
        "Neon Sunset": { "path": "shaders/sunset.frag" }
      },
      "background_music": [],
      "browser_sounds": {
        "CLICK": [], "HOVER": [], "HOVER_UP": [], "IMPORTANT_CLICK": [],
        "FEATURE_SWITCH_ON": [], "FEATURE_SWITCH_OFF": [], "LEVEL_UPGRADE": [],
        "LIMITER_ON": [], "LIMITER_OFF": [], "SWITCH_TOGGLE": [],
        "TAB_INSERT": [], "TAB_CLOSE": [], "TAB_SLASH": []
      },
      "keyboard_sounds": {
        "TYPING_LETTER": [], "TYPING_SPACE": [], "TYPING_BACKSPACE": [], "TYPING_ENTER": []
      },
      "page_styles": []
    }
  }
}
