{
  "name": "Matrix Green",
  "description": "Classic hacker terminal — phosphor green code rain on near-black.",
  "developer": { "name": "Latif" },
  "manifest_version": 3,
  "version": "1.0",
  "mod": {
    "license": "",
    "schema_version": 1,
    "payload": {
      "theme": {
        "dark": {
          "gx_accent":         { "h": 111, "s": 100, "l": 54 },
          "gx_secondary_base": { "h": 137, "s": 41, "l": 9 },
          "gx_accent_2":       { "h": 160, "s": 100, "l": 50 }
        },
        "light": {
          "gx_accent":         { "h": 111, "s": 70, "l": 32 },
          "gx_secondary_base": { "h": 120, "s": 25, "l": 95 },
          "gx_accent_2":       { "h": 160, "s": 70, "l": 28 }
        }
      },
      "wallpaper": {
        "dark":  { "type": "live", "source": "wallpaper.js" },
        "light": { "type": "live", "source": "wallpaper.js" }
      },
      "shaders": {
        "Phosphor": { "path": "shaders/phosphor.frag" }
      },
      "background_music": [],
      "browser_sounds": {
        "CLICK": [], "HOVER": [], "HOVER_UP": [], "IMPORTANT_CLICK": [],
        "FEATURE_SWITCH_ON": [], "FEATURE_SWITCH_OFF": [], "LEVEL_UPGRADE": [],
        "LIMITER_ON": [], "LIMITER_OFF": [], "SWITCH_TOGGLE": [],
        "TAB_INSERT": [], "TAB_CLOSE": [], "TAB_SLASH": []
      },
      "keyboard_sounds": {
        "TYPING_LETTER": [], "TYPING_SPACE": [], "TYPING_BACKSPACE": [], "TYPING_ENTER": []
      },
      "page_styles": []
    }
  }
}
