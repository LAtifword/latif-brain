<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/primary"
        android:elevation="4dp" />

    <!-- Scrollable Settings Container -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Backend Configuration Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Backend Configuration"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp" />

            <!-- Host Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/hostInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Backend Host"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Port Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/portInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Backend Port"
                    android:inputType="number" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Protocol Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/protocolInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Protocol (http/https)"
                    android:inputType="text" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Timeout Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <EditText
                    android:id="@+id/timeoutInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Connection Timeout (ms)"
                    android:inputType="number" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Connection Status -->
            <TextView
                android:id="@+id/testStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Status: Not tested"
                android:textSize="12sp"
                android:layout_marginBottom="16dp" />

            <!-- Test Connection Button -->
            <Button
                android:id="@+id/testButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="Test Connection"
                android:backgroundTint="@color/primary"
                android:layout_marginBottom="12dp" />

            <!-- Application Options Section -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Application Options"
                android:textStyle="bold"
                android:textSize="16sp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <!-- Auto Connect Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Auto Connect"
                    android:textSize="14sp" />

                <Switch
                    android:id="@+id/autoConnectSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <!-- Debug Logs Toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Debug Logs"
                    android:textSize="14sp" />

                <Switch
                    android:id="@+id/debugLogsSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="end">

        <!-- Reset Button -->
        <Button
            android:id="@+id/resetButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Reset"
            style="@style/Widget.AppCompat.Button.Borderless"
            android:textColor="@color/primary"
            android:layout_marginEnd="12dp" />

        <!-- Save Button -->
        <Button
            android:id="@+id/saveButton"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:text="Save"
            android:backgroundTint="@color/primary" />

    </LinearLayout>

</LinearLayout>
