# ============================================
# LATIF-NI Kimi Integration Environment
# ============================================

# --- Backend Mode ---
# Options: 'local' | 'cloud' | 'auto'
# local  = Ollama only
# cloud  = Moonshot API only
# auto   = Try local first, fallback to cloud
LATIF_MODE=auto

# --- Local Backend (Ollama) ---
OLLAMA_HOST=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:7b

# --- Cloud Backend (Moonshot / Kimi) ---
# Get your free API key at: https://platform.moonshot.ai
KIMI_API_KEY=your-moonshot-api-key-here
KIMI_BASE_URL=https://api.moonshot.cn/v1
KIMI_MODEL=kimi-k2.6

# --- Fallback Backend (optional) ---
# Used when primary backend fails
KIMI_FALLBACK_URL=http://127.0.0.1:11434/v1
KIMI_FALLBACK_MODEL=qwen2.5:7b
KIMI_FALLBACK_KEY=ollama

# --- Plugin System ---
KIMI_PLUGINS_DIR=./kimi-integration/plugins

# --- MCP Servers ---
# Path to MCP servers config JSON
KIMI_MCP_CONFIG=./kimi-integration/configs/mcp-servers.json

# --- Inference Defaults ---
# Preset: 'kimiK2' | 'local' | 'creative' | 'precise' | 'coding' | 'agent'
LATIF_DEFAULT_PRESET=local
LATIF_DEFAULT_SKILL=default

# --- Debug ---
# Set to 'true' for verbose logging
LATIF_DEBUG=false
