{
  "dependencies": {
    "openai": "^4.77.0",
    "dotenv": "^16.4.7"
  },
  "scripts": {
    "kimi:setup": "cp .env.kimi .env && echo 'Setup complete. Edit .env with your API keys.'",
    "kimi:test": "node -e "import('./kimi-integration/index.js').then(m => m.createLATIF()).then(l => l.chat('Hello')).then(r => console.log(r))"",
    "kimi:status": "node -e "import('./kimi-integration/index.js').then(m => m.createLATIF()).then(l => l.status()).then(s => console.log(JSON.stringify(s, null, 2)))""
  }
}
