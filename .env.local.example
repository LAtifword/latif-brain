# LATIF Environment Configuration - local

# App
NODE_ENV=local
LOG_LEVEL=info

# Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_TIMEOUT=30000

# API
API_PORT=8080
API_HOST=0.0.0.0

# Database
DATABASE_URL=indexeddb://latif

# Plugins
ENABLE_PLUGINS=true
PLUGINS_DIR=./plugins

# Features
ENABLE_WORKFLOWS=true
ENABLE_KNOWLEDGE_GRAPH=true
ENABLE_VISION=true
ENABLE_WEBHOOKS=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Security
ENABLE_AUTH=false
API_KEY_REQUIRED=false

# Development
ENABLE_HOT_RELOAD=false
ENABLE_DEBUG=false
